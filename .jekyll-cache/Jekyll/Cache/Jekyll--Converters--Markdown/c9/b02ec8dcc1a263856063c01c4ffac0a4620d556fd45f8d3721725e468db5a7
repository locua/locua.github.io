    <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="mi">0</span><span class="p">,</span><span class="nb">len</span><span class="p">(</span><span class="n">conf_matrix</span><span class="p">)):</span>
        <span class="n">tp_plus_fp</span><span class="o">=</span><span class="mi">0</span>
        <span class="k">for</span> <span class="n">j</span> <span class="ow">in</span> <span class="n">classes</span><span class="p">:</span>
            <span class="c1"># true positives + false positives
</span>            <span class="n">tp_plus_fp</span><span class="o">+=</span><span class="n">conf_matrix</span><span class="p">[</span><span class="n">j</span><span class="p">][</span><span class="n">i</span><span class="p">]</span>
        <span class="c1"># precision = true positives / true positives + false positives
</span>        <span class="n">class_precision</span><span class="o">=</span><span class="n">conf_matrix</span><span class="p">[</span><span class="n">i</span><span class="p">][</span><span class="n">i</span><span class="p">]</span><span class="o">/</span><span class="n">tp_plus_fp</span>
        <span class="n">precision</span><span class="p">[</span><span class="n">i</span><span class="p">]</span><span class="o">=</span><span class="n">class_precision</span>
    <span class="k">return</span> <span class="n">precision</span>

<span class="k">def</span> <span class="nf">myRecall</span><span class="p">(</span><span class="n">conf_matrix</span><span class="p">):</span>
