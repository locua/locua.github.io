<div class="language-python highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="k">def</span> <span class="nf">myPrecision</span><span class="p">(</span><span class="n">conf_matrix</span><span class="p">):</span>
    <span class="s">'''Takes confusion matrix returns precision'''</span>
    <span class="n">classes</span> <span class="o">=</span> <span class="n">np</span><span class="p">.</span><span class="n">unique</span><span class="p">(</span><span class="n">y</span><span class="p">)</span>
